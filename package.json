{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node server.js",
    "start": "npm run dev",
    "build": "echo 'No build step required for Vanilla JS'",
    "electron:dev": "concurrently \"node server.js\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "electron-builder"
  },
  "build": {
    "appId": "com.ticker.floating",
    "productName": "StockTicker",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "ui.js",
      "server.js",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "axios": "^1.16.0",
    "cheerio": "^1.2.0",
    "express": "^4.21.2",
    "lucide-react": "^0.479.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "wait-on": "^9.0.10"
  }
}
